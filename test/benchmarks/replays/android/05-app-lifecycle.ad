# App lifecycle.
context platform=android timeout=60000 retries=2

open settings --relaunch
appstate
snapshot -i
is exists "label=Display || label=Battery || label=Apps || label=\"Network & internet\" || label=\"Network and internet\""

click "label=Notifications"
wait "label=\"App notifications\" || label=\"Notification history\" || label=Bubbles || label=\"Notifications on lock screen\"" 5000
snapshot -i
is exists "label=\"App notifications\" || label=\"Notification history\" || label=Bubbles || label=\"Notifications on lock screen\""

home
wait 2000

open settings --relaunch
wait "label=Display || label=\"Display & touch\" || label=Battery || label=Apps || label=\"Network & internet\" || label=\"Network and internet\"" 5000
appstate
snapshot -i
screenshot "./test/screenshots/replays/android-lifecycle-reopen.png"

is exists "label=Display || label=\"Display & touch\" || label=Battery || label=Apps || label=\"Network & internet\" || label=\"Network and internet\""

back
wait "label=Display || label=\"Display & touch\" || label=Battery || label=Apps || label=Notifications" 3000
