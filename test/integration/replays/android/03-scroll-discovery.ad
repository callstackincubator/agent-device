# Scroll discovery.
context platform=android timeout=60000 retries=2

open settings --relaunch
snapshot -i
screenshot "./test/screenshots/replays/android-scroll-top.png"

is exists "text=\"Search Settings\" || text=\"Network & internet\" || text=\"Connected devices\" || text=Apps || text=Notifications"

scroll down 3
snapshot -i

scrollintoview "Accessibility" --max-scrolls 10
snapshot -i
is exists "text=Accessibility"
find text "Accessibility" exists

scroll up 8
snapshot -i
is exists "text=\"Search Settings\" || text=\"Network & internet\" || text=Apps || text=Notifications"
screenshot "./test/screenshots/replays/android-scroll-found.png"
