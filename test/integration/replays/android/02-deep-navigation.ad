# Deep navigation.
context platform=android timeout=60000 retries=2

open settings --relaunch
appstate
snapshot -i
screenshot "./test/screenshots/replays/android-deep-nav-root.png"

is exists "text=\"Search Settings\" || text=Apps || text=Notifications || text=Battery || text=\"Connected devices\""

click @e16
wait "text=\"App notifications\" || text=\"Notification history\" || text=Bubbles || text=\"Notifications on lock screen\"" 5000
snapshot -i
is exists "text=\"App notifications\" || text=\"Notification history\" || text=Bubbles || text=\"Notifications on lock screen\""
find text "Notification history" exists

click @e7
wait "text=\"Use notification history\" || text=\"No recent notifications\" || text=\"Recently dismissed\"" 5000
snapshot -i
screenshot "./test/screenshots/replays/android-deep-nav-detail.png"
is exists "text=\"Use notification history\" || text=\"No recent notifications\" || text=\"Recently dismissed\""

back
wait "text=\"App notifications\" || text=\"Notification history\" || text=Bubbles || text=\"Notifications on lock screen\"" 3000
snapshot
is exists "text=\"App notifications\" || text=\"Notification history\" || text=Bubbles || text=\"Notifications on lock screen\""

back
wait "text=\"Search Settings\" || text=Apps || text=Notifications || text=Battery || text=\"Connected devices\"" 3000
is exists "text=\"Search Settings\" || text=Apps || text=Notifications || text=Battery || text=\"Connected devices\""
